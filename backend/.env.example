# Oracle DB (SQL Developer에서 팀원이 공유하는 접속정보)
ORACLE_HOST=
ORACLE_PORT=1521
ORACLE_SERVICE_NAME=
ORACLE_USER=
ORACLE_PASSWORD=
ORACLE_POOL_MIN=1
ORACLE_POOL_MAX=3
SQLALCHEMY_POOL_SIZE=3
SQLALCHEMY_MAX_OVERFLOW=2

# TMDB (실시간 개인화 추천 후보와 과제용 시드 수집)
TMDB_API_KEY=

# 카카오 도서 검색 (도서 메타데이터 수집)
KAKAO_BOOKS_API_KEY=

# 네이버 도서 검색 (도서 메타데이터 수집 - 보조 소스)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# 알라딘 도서 검색 (도서 메타데이터 수집 - 보조 소스)
ALADIN_TTB_KEY=

# 구글 도서 API (도서 메타데이터 수집 - 보조 소스)
GOOGLE_BOOKS_API_KEY=

# LLM (분류/추천신호추출/NL2SQL 생성) - 팀 확정 전이라 둘 다 자리만
LLM_PROVIDER=gemini
GEMINI_API_KEY=
# 프로젝트별 무료 할당량 정책에 따라 특정 모델이 429로 막힐 수 있음(기본값: gemini-3.5-flash).
GEMINI_MODEL=
ANTHROPIC_API_KEY=

# Kakao Map (근처 서점/도서관 검색)
KAKAO_MAP_API_KEY=

# 프론트 CORS 허용 origin
FRONTEND_ORIGIN=http://localhost:3000

# 로그인 세션 (운영 HTTPS에서는 반드시 true, lax 권장)
SESSION_COOKIE_NAME=moodpick_session
CSRF_COOKIE_NAME=moodpick_csrf
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
SESSION_TTL_DAYS=14
